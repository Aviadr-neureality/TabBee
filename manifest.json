{
  "manifest_version": 3,
  "name": "TabBee",
  "version": "1.0",
  "description": "The Busy Bee that Organizes Your Tabs!",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "tabs",
    "tabGroups",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "host_permissions": ["<all_urls>"]
}
